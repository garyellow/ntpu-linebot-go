# NTPU LineBot Go - Environment Configuration
# Copy this file to .env. Full reference: docs/configuration.md

# ── Required ─────────────────────────────────────────────────────────────────
NTPU_LINE_CHANNEL_ACCESS_TOKEN=your_access_token_here
NTPU_LINE_CHANNEL_SECRET=your_channel_secret_here

# ── Server ───────────────────────────────────────────────────────────────────
#NTPU_PORT=10000
#NTPU_LOG_LEVEL=info              # debug | info | warn | error
#NTPU_SHUTDOWN_TIMEOUT=30s
#NTPU_SERVER_NAME=ntpu-linebot-go-01         # appears in logs, metrics, Sentry
#NTPU_INSTANCE_ID=ntpu-linebot-go-01-pod-abc123

# ── Data & Scraping ──────────────────────────────────────────────────────────
#NTPU_DATA_DIR=/data              # default: /data (Linux/Mac) or ./data (Windows)
#NTPU_CACHE_TTL=168h              # contacts/courses/programs TTL (7 days)
#NTPU_SCRAPER_TIMEOUT=60s
#NTPU_SCRAPER_MAX_RETRIES=10
#NTPU_WEBHOOK_TIMEOUT=60s

# ── Rate Limits ──────────────────────────────────────────────────────────────
#NTPU_GLOBAL_RATE_RPS=100
#NTPU_USER_RATE_BURST=15
#NTPU_USER_RATE_REFILL=0.1        # tokens/s; 0.1 = 1 per 10 s
#NTPU_LLM_RATE_BURST=60
#NTPU_LLM_RATE_REFILL=30          # tokens/hour
#NTPU_LLM_RATE_DAILY=180          # 0 = disabled

# ── Background Jobs ──────────────────────────────────────────────────────────
#NTPU_WARMUP_WAIT=false           # block /webhook until warmup finishes
#NTPU_WARMUP_GRACE_PERIOD=10m
#NTPU_MAINTENANCE_REFRESH_INTERVAL=24h
#NTPU_MAINTENANCE_CLEANUP_INTERVAL=24h

# ── LLM (optional) ───────────────────────────────────────────────────────────
# Set NTPU_LLM_ENABLED=true and provide at least one API key.
# Providers are tried in order; model lists are comma-separated with fallback priority.
#NTPU_LLM_ENABLED=false
#NTPU_LLM_PROVIDERS=gemini,groq,cerebras,openai

#NTPU_GEMINI_API_KEY=
#NTPU_GEMINI_INTENT_MODELS=gemma-4-31b-it,gemma-4-26b-a4b-it
#NTPU_GEMINI_EXPANDER_MODELS=gemma-4-31b-it,gemma-4-26b-a4b-it

#NTPU_GROQ_API_KEY=
#NTPU_GROQ_INTENT_MODELS=openai/gpt-oss-120b,openai/gpt-oss-20b,llama-3.3-70b-versatile,qwen/qwen3-32b,llama-3.1-8b-instant
#NTPU_GROQ_EXPANDER_MODELS=openai/gpt-oss-120b,openai/gpt-oss-20b,llama-3.3-70b-versatile,qwen/qwen3-32b,llama-3.1-8b-instant

#NTPU_CEREBRAS_API_KEY=
#NTPU_CEREBRAS_INTENT_MODELS=gpt-oss-120b,llama3.1-8b
#NTPU_CEREBRAS_EXPANDER_MODELS=gpt-oss-120b,llama3.1-8b

#NTPU_OPENAI_API_KEY=
#NTPU_OPENAI_ENDPOINT=http://localhost:1234/v1/  # any OpenAI-compatible endpoint
#NTPU_OPENAI_INTENT_MODELS=your-model-name
#NTPU_OPENAI_EXPANDER_MODELS=your-model-name

# ── S3-Compatible Snapshot Sync (optional) ───────────────────────────────────
# Enables shared SQLite snapshots for multi-node deployments.
# Requires conditional PutObject (If-Match/If-None-Match). Min lock TTL: 30s.
#NTPU_S3_ENABLED=false
#NTPU_S3_ENDPOINT=https://your-s3-compatible-endpoint.example.com
#NTPU_S3_REGION=us-east-1
#NTPU_S3_ACCESS_KEY_ID=your_s3_access_key_id
#NTPU_S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
#NTPU_S3_BUCKET_NAME=ntpu-linebot-snapshots
#NTPU_S3_SNAPSHOT_KEY=snapshots/cache.db.zst
#NTPU_S3_LOCK_KEY=locks/leader.json
#NTPU_S3_LOCK_TTL=1h              # min 30s; renews at TTL/3
#NTPU_S3_SNAPSHOT_POLL_INTERVAL=15m
#NTPU_S3_DELTA_PREFIX=deltas
#NTPU_S3_SCHEDULE_KEY=schedules/maintenance.json

# ── Observability (optional) ─────────────────────────────────────────────────

#NTPU_SENTRY_ENABLED=false
#NTPU_SENTRY_DSN=https://your_sentry_application_token_here@sentry.example.com/1
#NTPU_SENTRY_ENVIRONMENT=production
#NTPU_SENTRY_RELEASE=ntpu-linebot-go@1.0.0
#NTPU_SENTRY_SAMPLE_RATE=1.0      # error sampling: 0.0–1.0
#NTPU_SENTRY_TRACES_SAMPLE_RATE=0.0  # trace sampling: 0.0 = disabled

#NTPU_BETTERSTACK_ENABLED=false
#NTPU_BETTERSTACK_TOKEN=your_betterstack_source_token_here
#NTPU_BETTERSTACK_ENDPOINT=https://in.logs.betterstack.com

#NTPU_METRICS_AUTH_ENABLED=false
#NTPU_METRICS_USERNAME=prometheus
#NTPU_METRICS_PASSWORD=your_secure_password_here
